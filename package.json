{
  "name": "dev-workspace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "vite --port=5173 --host=0.0.0.0",
    "dev:api": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "build:web": "vite build",
    "build:api": "tsc -p server/tsconfig.json",
    "build": "npm run build:web && npm run build:api",
    "start": "NODE_ENV=production node server/dist/index.js",
    "preview": "vite preview",
    "clean": "rm -rf dist server/dist",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "security-check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@clerk/clerk-react": "5.61.4",
    "@clerk/express": "2.0.8",
    "@google/genai": "1.29.0",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.1.14",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "5.0.4",
    "clsx": "2.1.1",
    "cors": "2.8.6",
    "date-fns": "4.1.0",
    "dotenv": "17.2.3",
    "express": "4.21.2",
    "helmet": "8.1.0",
    "lucide-react": "0.546.0",
    "mongodb": "6.19.0",
    "motion": "12.23.24",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "svix": "1.89.0",
    "tailwind-merge": "3.5.0",
    "vite": "6.2.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "4.17.21",
    "@types/helmet": "0.0.48",
    "@types/node": "22.14.0",
    "autoprefixer": "10.4.21",
    "concurrently": "9.2.1",
    "tailwindcss": "4.1.14",
    "tsx": "4.21.0",
    "typescript": "5.8.2",
    "vite": "6.2.0"
  }
}
